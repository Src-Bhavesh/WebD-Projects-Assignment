<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Dashboard</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      background: #000;
      margin: 0;
      color: #fff;
      overflow: hidden;
      position: relative;
    }

    /* Hurricane Swirl Effect */
    .hurricane-swirl {
      position: absolute;
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 70%);
      animation: spin 20s linear infinite;
      z-index: 0;
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .rain {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .drop {
      position: absolute;
      background: rgba(255, 255, 255, 0.1);
      width: 1px;
      height: 20px;
      animation: rain 1s linear infinite;
    }

    @keyframes rain {
      to { transform: translateY(100vh); }
    }

    h1, .nav-button { z-index: 1; }

    h1 { font-weight: 300; letter-spacing: 2px; margin-bottom: 40px; }

    .nav-button {
      text-decoration: none;
      background-color: rgba(255, 255, 255, 0.05);
      color: #fff;
      padding: 15px 30px;
      margin: 10px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(255, 255, 255, 0.1);
      transition: all 0.4s ease;
      font-weight: 500;
      width: 200px;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nav-button:hover {
      background: linear-gradient(135deg, #007bff, #0056b3);
      transform: scale(1.05);
    }
  </style>
</head>
<body>

  <div class="hurricane-swirl"></div>
  <div class="rain" id="rain"></div>

  <h1>Student Management System</h1>

  <a href="/getdata" class="nav-button">Show Data</a>
  <a href="/insertdata" class="nav-button">Insert Data</a>

  <script>
    const rainContainer = document.getElementById('rain');
    for (let i = 0; i < 150; i++) {
      const drop = document.createElement('div');
      drop.classList.add('drop');
      drop.style.left = Math.random() * 100 + 'vw';
      drop.style.animationDuration = Math.random() * 0.5 + 0.5 + 's';
      drop.style.animationDelay = Math.random() * 2 + 's';
      rainContainer.appendChild(drop);
    }
  </script>
</body>
</html>