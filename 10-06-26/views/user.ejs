<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile</title>
</head>
<body>
  <h1>Home Page</h1>
  <h2>Name: <%= dipesh.name %></h2>
  <h2>Color: <%= color %></h2>
  
  <% if (dipesh.age < 18) { %>
    <h3>Vote nhi de sakta</h3>
  <% } else { %>
    <h3>Vote de sakta hai</h3>
  <% } %>

  <% for (let i = flag; i <= 25; i++) { %>
    <h4><%= i %></h4>
  <% } %>
</body>
</html>